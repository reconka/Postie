{
  "name": "postie",
  "displayName": "Postie",
  "repository": {
    "type": "git",
    "url": "https://github.com/reconka/Postie.git"
  },
  "bugs": {
    "url": "https://github.com/reconka/Postie/issues"
  },
  "homepage": "https://github.com/reconka/Postie",
  "pricing": "Free",
  "keywords": [
    "email",
    "mcp",
    "server",
    "smtp",
    "debug"
  ],
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "description": "Your development emails, caught and managed in VS Code",
  "sponsor": {
    "url": "https://github.com/sponsors/reconka/"
  },
  "version": "1.1.3",
  "icon": "out/postie-profile.jpg",
  "activationEvents": [
    "onStartupFinished"
  ],
  "publisher": "Postie",
  "engines": {
    "vscode": "^1.102.0"
  },
  "main": "out/extension.js",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "postie.mcp-server",
        "label": "Postie MCP Server"
      }
    ],
    "walkthroughs": [
      {
        "id": "postie-getting-started",
        "title": "Getting Started with Postie",
        "description": "Learn how to use Postie to catch, view, and manage emails directly within VS Code.",
        "steps": [
          {
            "id": "postie-intro",
            "title": "Introduction to Postie",
            "description": "Postie is an email catcher server that runs in the background, allowing you to view emails, attachments, and preview emails in different screen sizes directly within VS Code.",
            "media": {
              "image": "./out/welcome.jpg",
              "altText": "Postie introduction"
            }
          },
          {
            "id": "postie-config",
            "title": "Configure your application to use Postie",
            "description": "To start using Postie, you need to configure your application to send emails to the Postie SMTP server. You can configure the SMTP server port in the [Postie settings](command:workbench.action.openSettings?%22postie%22). ",
            "media": {
              "markdown": "/out/integration.md"
            }
          },
          {
            "id": "postie-view-emails",
            "title": "Viewing Emails",
            "description": "Navigate to the primary sidebar and click on the Postie icon to view all received emails. From there, you can click on any email to see its details, access attachments, and download the email as an .eml file.",
            "media": {
              "image": "./out/email-preview.gif",
              "altText": "Viewing emails in Postie"
            }
          },
          {
            "id": "postie-preview-emails",
            "title": "Previewing Emails",
            "description": "To ensure your emails look fantastic on every device, preview them in tablet, mobile, and desktop views. For clicking on a link, press CMD and click simultaneously.",
            "media": {
              "image": "./out/email-details-preview.gif",
              "altText": "Previewing emails in Postie"
            }
          },
          {
            "id": "postie-quick-commands",
            "title": "Using Quick Commands",
            "description": "Access quick commands by pressing `Cmd+P` (Mac) or `Ctrl+P` (Windows/Linux) and typing 'Postie' to start, stop, restart the server, or delete emails.",
            "media": {
              "image": "./out/email-quick-command.gif",
              "altText": "Using quick commands in Postie"
            }
          }
        ]
      },
      {
        "id": "postie-mcp-guide",
        "title": "Use Postie MCP in VS Code",
        "description": "Connect VS Code chat tools to Postie and inspect emails by id, screenshots, and compatibility checks.",
        "steps": [
          {
            "id": "postie-mcp-prerequisites",
            "title": "Check Prerequisites",
            "description": "Use a VS Code build with MCP support, install Postie, and make sure at least one email is captured.",
            "media": {
              "markdown": "/MCP_VSCODE_GUIDE.md"
            }
          },
          {
            "id": "postie-mcp-enable-server",
            "title": "Enable Postie MCP Server",
            "description": "Open the Command Palette and run `MCP: List Servers`, then enable `Postie MCP Server`.",
            "media": {
              "markdown": "/MCP_VSCODE_GUIDE.md"
            }
          },
          {
            "id": "postie-mcp-discover-tools",
            "title": "Discover Tools",
            "description": "In VS Code chat tool configuration, enable Postie tools including `list_emails`, `get_email`, `capture_email_screenshot`, and compatibility tools.",
            "media": {
              "markdown": "/MCP_VSCODE_GUIDE.md"
            }
          },
          {
            "id": "postie-mcp-debug-workflow",
            "title": "Run Debug Workflow",
            "description": "Ask chat to list emails, copy an `emailId`, inspect details, run compatibility checks, then generate screenshots from `capture_email_screenshot`.",
            "media": {
              "markdown": "/MCP_VSCODE_GUIDE.md"
            }
          },
          {
            "id": "postie-mcp-settings",
            "title": "Tune MCP Settings",
            "description": "Configure [Postie settings](command:workbench.action.openSettings?%22postie%22) like `postie.compatibilityClients` and `postie.screenshotPresets` to control MCP defaults.",
            "media": {
              "markdown": "/MCP_VSCODE_GUIDE.md"
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "Postie",
      "properties": {
        "postie.smtpServerPort": {
          "type": "number",
          "default": 587,
          "description": "SMTP server port"
        },
        "postie.smtpUsername": {
          "type": "string",
          "default": "postie",
          "description": "SMTP server username"
        },
        "postie.smtpPassword": {
          "type": "string",
          "default": "postie",
          "description": "SMTP server password"
        },
        "postie.allowExternalMails": {
          "type": "boolean",
          "default": false,
          "description": "Allow external emails to be received",
          "comment": "This is useful for testing emails sent from external sources"
        },
        "postie.showNewEmailNotification": {
          "type": "boolean",
          "default": true,
          "description": "Show notification when new email arrives"
        },
        "postie.compatibilityClients": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "apple-mail.macos",
              "apple-mail.ios",
              "gmail.desktop-webmail",
              "gmail.ios",
              "gmail.android",
              "gmail.mobile-webmail",
              "orange.desktop-webmail",
              "orange.ios",
              "orange.android",
              "outlook.windows",
              "outlook.windows-mail",
              "outlook.macos",
              "outlook.ios",
              "outlook.android",
              "yahoo.desktop-webmail",
              "yahoo.ios",
              "yahoo.android",
              "aol.desktop-webmail",
              "aol.ios",
              "aol.android",
              "samsung-email.android",
              "sfr.desktop-webmail",
              "sfr.ios",
              "sfr.android",
              "thunderbird.macos",
              "protonmail.desktop-webmail",
              "protonmail.ios",
              "protonmail.android",
              "hey.desktop-webmail",
              "mail-ru.desktop-webmail",
              "fastmail.desktop-webmail",
              "laposte.desktop-webmail"
            ]
          },
          "uniqueItems": true,
          "default": [
            "apple-mail.ios",
            "gmail.ios",
            "gmail.android",
            "outlook.windows"
          ],
          "markdownDescription": "Email clients to test compatibility. The default is set to test compatibility with Apple Mail, Gmail, and Outlook. Do you want to set a different client? [Check the list of supported clients](https://www.npmjs.com/package/@jsx-email/doiuse-email#emailclients)"
        },
        "postie.screenshotPresets": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "iphone-se",
              "iphone-xr",
              "iphone-12-pro",
              "iphone-14-pro-max",
              "pixel-7",
              "samsung-galaxy-s8-plus",
              "samsung-galaxy-s20-ultra",
              "samsung-galaxy-a51-71",
              "ipad-mini",
              "ipad-air",
              "ipad-pro"
            ]
          },
          "uniqueItems": true,
          "default": [
            "iphone-14-pro-max",
            "pixel-7",
            "ipad-air"
          ],
          "markdownDescription": "Allowed screenshot preset IDs for MCP screenshot capture. Legacy aliases `desktop`, `tablet`, and `mobile` remain supported for compatibility."
        },
        "postie.mcpStoragePath": {
          "type": "string",
          "default": "",
          "description": "Override Postie MCP storage path. If unset, Postie will auto-discover and prompt when multiple folders are found."
        },
        "postie.defaultEmailView": {
          "type": "string",
          "default": "desktop",
          "enum": [
            "desktop",
            "tablet",
            "mobile",
            "compatibility",
            "text-only"
          ],
          "description": "Default email view"
        },
        "postie.runServerOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Automatically run the server on startup"
        },
        "postie.maxStoredEmailsCount": {
          "type": "number",
          "default": 100,
          "description": "Maximum number of emails to store"
        },
        "postie.maxEmailSize": {
          "type": "number",
          "default": 1048576,
          "description": "Maximum email size in bytes default is 1MB"
        }
      }
    },
    "viewsWelcome": [
      {
        "view": "incomingEmails",
        "contents": "Welcome to Postie! Click the play button to start the server.",
        "when": "!postie.isRunning"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mailView",
          "title": "Postie",
          "icon": "./out/postie-icon.svg"
        }
      ]
    },
    "views": {
      "mailView": [
        {
          "id": "incomingEmails",
          "name": "Incoming Emails"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "postie.deleteSelectedEmail",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "postie.deleteEmailDetails",
          "group": "navigation@1",
          "when": "view == incomingEmails && postie.isRunning"
        },
        {
          "command": "postie.restartServer",
          "group": "navigation@1",
          "when": "view == incomingEmails && !postie.isRunning"
        },
        {
          "command": "postie.stopServer",
          "group": "navigation@1",
          "when": "view == incomingEmails && postie.isRunning"
        }
      ],
      "view/item/context": [
        {
          "command": "postie.deleteSelectedEmail",
          "group": "inline",
          "icon": "$(trash)",
          "when": "view == incomingEmails && viewItem == email"
        }
      ]
    },
    "commands": [
      {
        "command": "postie.deleteEmailDetails",
        "title": "Postie: Delete all emails",
        "icon": "$(trash)"
      },
      {
        "command": "postie.deleteSelectedEmail",
        "title": "Delete selected email",
        "when": "view == incomingEmails",
        "icon": "$(trash)"
      },
      {
        "command": "postie.stopServer",
        "title": "Postie: Stop Email Server",
        "icon": "$(debug-stop)"
      },
      {
        "command": "postie.restartServer",
        "title": "Postie: Restart Email Server",
        "icon": "$(play)"
      },
      {
        "command": "postie.setupMcpForEditors",
        "title": "Postie: Setup MCP for Other Editors",
        "icon": "$(gear)"
      },
      {
        "command": "postie.setupMcpForCodex",
        "title": "Postie: Setup MCP for Codex",
        "icon": "$(gear)"
      },
      {
        "command": "postie.setupMcpForClaudeCode",
        "title": "Postie: Setup MCP for Claude Code",
        "icon": "$(gear)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node ./esbuild.js",
    "test": "jest",
    "package": "NODE_ENV=production node ./esbuild.js",
    "watch": "node ./esbuild.js --watch",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "24.x",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@types/sanitize-html": "^2.16.1",
    "@types/vscode": "^1.102.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "glob": "^13.0.6",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@types/mailparser": "^3.4.6",
    "@types/smtp-server": "^3.5.12",
    "@vscode-elements/react-elements": "^1.15.1",
    "@vscode/codicons": "^0.0.45",
    "date-fns": "^4.1.0",
    "doiuse-email": "^0.4.1",
    "esbuild-plugin-copy": "^2.1.1",
    "mailparser": "^3.9.6",
    "nodemailer": "^8.0.4",
    "playwright": "^1.58.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sanitize-html": "^2.17.2",
    "smtp-server": "^3.18.3",
    "zod": "^4.3.6"
  }
}
